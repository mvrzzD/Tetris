<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="Tetris3" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/Tetris3" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
					<Add directory="include" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/Tetris3" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
					<Add directory="include" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-fexceptions" />
			<Add directory="SFML/include" />
		</Compiler>
		<Linker>
			<Add library="sfml-graphics" />
			<Add library="sfml-window" />
			<Add library="sfml-system" />
			<Add library="sfml-audio" />
			<Add directory="SFML/lib" />
		</Linker>
		<Unit filename="include/Audio.h" />
		<Unit filename="include/Board.h" />
		<Unit filename="include/Game.h" />
		<Unit filename="include/Menu.h" />
		<Unit filename="include/Piece.h" />
		<Unit filename="include/UI.h" />
		<Unit filename="main.cpp" />
		<Unit filename="src/Audio.cpp" />
		<Unit filename="src/Board.cpp" />
		<Unit filename="src/Game.cpp" />
		<Unit filename="src/Menu.cpp" />
		<Unit filename="src/Piece.cpp" />
		<Unit filename="src/UI.cpp" />
		<Extensions />
	</Project>
</CodeBlocks_project_file>
